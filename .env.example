# Example environment variables for Nyodera Heights
# Copy this to a local `.env` file and populate with real values.

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY

# PayPal
PAYPAL_CLIENT_ID=sb_YOUR_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_SECRET

# M-Pesa (optional)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# Email / Sending provider (choose one approach)
# Option A: Provider API (recommended for transactional email)
EMAIL_PROVIDER=unione
EMAIL_API_URL=
EMAIL_API_KEY=

# Option B: Generic API adapter
EMAIL_API_URL=
EMAIL_API_KEY=

# Option C: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_REJECT_UNAUTHORIZED=true

# Mail headers / defaults
EMAIL_FROM=no-reply@nyoderaheights.com
EMAIL_SUBJECT=Nyodera Heights Notification
EMAIL_SUBJECT_OTP=Nyodera Heights Email Verification
EMAIL_ENVELOPE_FROM=no-reply@nyoderaheights.com

# Application-specific email settings (non-secret)
# The sending domain and confirmed sending address you supplied
EMAIL_SENDING_DOMAIN=sandbox-7150788-12ba29.unionemailer.com
CONFIRMED_SENDING_ADDRESS=barackjuma911@gmail.com

# IMPORTANT: Do NOT commit a real `.env` with secrets to source control.
# Web API (preferred when you have an API key)
# Example: SendGrid v3 endpoint or other provider HTTP endpoint
EMAIL_PROVIDER=unione
EMAIL_API_URL=https://api.unione.example/v1/messages
EMAIL_API_KEY=your_api_key_here

# SMTP (alternative). For SendGrid SMTP use SMTP_USER=apikey and SMTP_PASS=<API key>
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_api_key_here
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=false

# Optional settings
EMAIL_FROM=no-reply@yourdomain.com

# Do NOT commit your real secrets. Copy this to a local `.env` and set real values.
